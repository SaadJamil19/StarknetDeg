STARKNET_RPC_URL=https://<your-starknet-rpc-endpoint>
ETH_RPC_URL=https://<your-ethereum-rpc-endpoint>

PGHOST=db
PGPORT=5432
PGUSER=postgres
PGPASSWORD=<STRONG_RANDOM_PASSWORD>
PGDATABASE=StarknetDeg

# Optional host-side DB exposure for debugging from psql/IDE.
PGHOST_BIND_ADDRESS=127.0.0.1
PGHOST_PORT=5438
PGSTATEMENT_TIMEOUT_MS=60000
PGQUERY_TIMEOUT_MS=65000
PGIDLE_TIMEOUT_MS=10000
EXIT_ON_DB_DISCONNECT=true
DB_POOL_MAX_MAIN=10
DB_POOL_MAX_BACKFILL=5

RUN_MIGRATIONS=true
DB_WAIT_RETRIES=120
DB_WAIT_DELAY_SECONDS=2
MIGRATION_RETRIES=120
MIGRATION_RETRY_DELAY_MS=1000

INDEXER_KEY=starknetdeg-mainnet
INDEXER_LANE=ACCEPTED_ON_L2
INDEXER_START_MODE=genesis
INDEXER_START_BLOCK=0

# Main indexer turbo settings.
INDEXER_POLL_INTERVAL_MS=2000
INDEXER_CATCHUP_BATCH_SIZE=100
INDEXER_TURBO_MODE=true
INDEXER_TURBO_PARALLELISM=8
INDEXER_SKIP_REALTIME=true
INDEXER_PREFETCH_WINDOW_SIZE=50
INDEXER_PREFETCH_WINDOW_MAX=400
INDEXER_PREFETCH_CONCURRENCY=10
INDEXER_SMALL_BLOCK_TX_THRESHOLD=5
INDEXER_SMALL_BLOCK_GROWTH_FACTOR=2
INDEXER_TURBO_REBUILD_AT_LAG=10000
INDEXER_TURBO_LOCAL_PREFETCH_SIZE=32MB
INDEXER_TRANSFER_UPSERT_BATCH_SIZE=1000
INDEXER_TRADE_UPSERT_BATCH_SIZE=1000

# RPC batch mode: auto | on | off.
STARKNET_RPC_BATCH_SUPPORT=auto
STARKNET_RPC_BATCH_MAX_REQUESTS=100
STARKNET_RPC_FALLBACK_CONCURRENCY=10

# Parallel backfill worker settings.
BACKFILL_START_BLOCK=0
BACKFILL_END_BLOCK=9000000
BACKFILL_TOTAL_WORKERS=4
BACKFILL_WORKER_INDEX=
BACKFILL_CHUNK_SIZE=2000000
BACKFILL_WINDOW_SIZE=50
BACKFILL_WINDOW_MAX=800
BACKFILL_PARALLELISM=8
BACKFILL_POLL_INTERVAL_MS=1000
BACKFILL_SMALL_BLOCK_TX_THRESHOLD=5
BACKFILL_SMALL_BLOCK_GROWTH_FACTOR=2
BACKFILL_INDEXER_KEY_PREFIX=starknetdeg-mainnet-backfill
BACKFILL_INDEX_LEADER=true

# Defer heavy phase-6 jobs during deep backfill.
LIVE_WINDOW_BLOCK_LAG=1000
PHASE6_DEFER_CHECK_INTERVAL_MS=30000
HEALTHCHECK_PORT=3100
HEALTHCHECK_PM2_TIMEOUT_MS=3000
PM2_REQUIRED_PROCESSES=main-indexer,phase4-workers,phase6-workers,l1-indexer,l1-matcher

ETH_INDEXER_BATCH_SIZE=100
ETH_INDEXER_POLL_INTERVAL_MS=5000

PHASE3_PRICE_STALE_AFTER_BLOCKS=600
PHASE3_MIN_PATH_LIQUIDITY_USD=50000
PHASE3_BRIDGE_SYMBOLS=STRK,ETH,WBTC,USDC,USDT,DAI

CMC_API_KEY=<YOUR_CMC_API_KEY>
CMC_ALLOWED_SYMBOLS=STRK,ETH,WBTC,WSTETH,EKUBO
CMC_CACHE_TTL_MS=60000
